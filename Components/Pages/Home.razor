@page "/"
@rendermode InteractiveServer

<PageTitle>Click Counter</PageTitle>

<div class="min-vh-100 d-flex align-items-center" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">

                <div class="text-center mb-4">
                    <h2 class="text-white fw-bold">Click Counter</h2>
                    <p class="text-white opacity-75">Track your clicks</p>
                </div>

                <div class="card border-0 shadow-lg text-center" style="border-radius:24px;">
                    <div class="card-body p-5">

                        <div class="mb-2">
                            <span class="text-muted small fw-semibold text-uppercase">Total Clicks</span>
                        </div>

                        <div class="fw-bold mb-4" style="font-size:6rem; line-height:1; background: linear-gradient(135deg, #f093fb, #f5576c); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">
                            @count
                        </div>

                        <button class="btn btn-lg fw-bold w-100 mb-3 py-3 text-white"
                                style="border-radius:14px; background: linear-gradient(135deg, #f093fb, #f5576c); border:none; font-size:1.1rem; box-shadow: 0 4px 15px rgba(240,147,251,0.4);"
                                @onclick="IncrementCount">
                            👆 Click Me!
                        </button>

                        <button class="btn btn-outline-secondary w-100 rounded-pill mb-4" @onclick="ResetCount">
                            Reset to Zero
                        </button>

                        <div class="border-top pt-4">
                            <label class="form-label text-muted small fw-semibold text-uppercase mb-2">
                                Set Count Manually
                            </label>
                            <div class="input-group">
                                <button class="btn btn-outline-secondary fw-bold" style="border-radius:10px 0 0 10px;" @onclick="Decrement">−</button>
                                <input type="number" @bind="count" @bind:event="oninput"
                                       class="form-control text-center fw-bold border-start-0 border-end-0"
                                       style="font-size:1.2rem;" min="0" />
                                <button class="btn btn-outline-secondary fw-bold" style="border-radius:0 10px 10px 0;" @onclick="Increment">+</button>
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@code {
    private int count = 0;
    private void IncrementCount() => count++;
    private void ResetCount() => count = 0;
    private void Increment() => count++;
    private void Decrement() => count = Math.Max(0, count - 1);
}
